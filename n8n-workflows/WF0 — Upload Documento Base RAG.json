    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=INSERT INTO rag_stores (id, store_name, store_type, description, file_count, session_id, created_at, updated_at)\nVALUES (\n  gen_random_uuid(),\n  '{{ $('Crear store base en Gemini').first().json.name }}',\n  'base',\n  'Repositorio centralizado - Normas IIA y documentación base',\n  0,\n  NULL,\n  NOW(),\n  NOW()\n)\nRETURNING store_name",
        "options": {}
