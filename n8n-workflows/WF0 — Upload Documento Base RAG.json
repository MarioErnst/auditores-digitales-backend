    {
      "parameters": {
        "jsCode": "const json = $input.first().json.body || {};\nconst binary = $input.first().binary;\n\nconst filename = json.filename;\nconst description = json.description || '';\n\nif (!filename) throw new Error('filename es requerido');\nif (!binary || Object.keys(binary).length === 0) {\n  throw new Error('No hay archivo binario adjunto');\n}\n\nconst binaryKey = Object.keys(binary)[0];\nconst binaryData = binary[binaryKey];\n\nconst ext = filename.split('.').pop().toLowerCase();\nconst mimeMap = {\n  'pdf':  'application/pdf',\n  'docx': 'application/vnd.openxmlformats-officedocument.wordprocessingml.document',\n  'doc':  'application/msword',\n  'xlsx': 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',\n  'xls':  'application/vnd.ms-excel',\n  'csv':  'text/csv',\n  'txt':  'text/plain',\n  'json': 'application/json',\n  'md':   'text/markdown',\n  'html': 'text/html',\n  'pptx': 'application/vnd.openxmlformats-officedocument.presentationml.presentation'\n};\nconst mimetype = binaryData?.mimeType || mimeMap[ext] || 'application/octet-stream';\n\nreturn [{\n  json: {\n    filename: filename,\n    description: description,\n    mimetype: mimetype\n  },\n  binary: binary\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1024,
        112
      ],
      "id": "54c6bb16-abf6-457d-bc0c-10a00a4feed8",
      "name": "Extraer archivo"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT store_name FROM rag_stores WHERE store_type = 'base' LIMIT 1",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
