        }
      }
    },
    {
      "parameters": {
        "jsCode": "let storeName;\nlet prev;\n\ntry {\n  storeName = $('Guardar store base en BD').first().json.store_name;\n  prev = $('¿Existe store base?').first();\n} catch(e) {\n  prev = $('¿Existe store base?').first();\n  storeName = prev.json.base_store_name;\n}\n\nreturn [{\n  json: {\n    filename: prev.json.filename,\n    description: prev.json.description,\n    mimetype: prev.json.mimetype,\n    store_name: storeName\n  },\n  binary: prev.binary\n}];"
      },
