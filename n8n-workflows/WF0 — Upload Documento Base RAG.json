        "postgres": {
          "id": "ApHxYg0HkRvwN2Sw",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const storeResult = $('Buscar store base (BD)').first().json;\nconst fileData = $('Extraer archivo').first().json;\n\nconst existingStoreName = storeResult.store_name || null;\n\nreturn [{\n  json: {\n    filename: fileData.filename,\n    description: fileData.description,\n    mimetype: fileData.mimetype,\n    base_store_name: existingStoreName,\n    needs_new_store: existingStoreName === null\n  },\n  binary: $('Extraer archivo').first().binary\n}];"
      },
