              "id": "cond-01",
              "leftValue": "={{ $json.needs_new_store }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
