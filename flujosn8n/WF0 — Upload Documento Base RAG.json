      "id": "b2c3305c-2780-47e7-8f57-0a22dfcfc42e",
      "name": "Crear store base en Gemini"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO rag_stores (id, store_name, store_type, descripcion, archivos_count, session_id, created_at, updated_at)\nVALUES (\n  gen_random_uuid(),\n  '{{ $('Crear store base en Gemini').first().json.name }}',\n  'base',\n  'Repositorio centralizado - Normas IIA y documentación base',\n  0,\n  NULL,\n  NOW(),\n  NOW()\n)\nRETURNING store_name",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        384,
        -112
      ],
      "id": "06c4b929-7840-4de2-b7b9-6d3b86ec924b",
      "name": "Guardar store base en BD"
    },
    {
      "parameters": {
        "jsCode": "let storeName;\nlet prev;\n\ntry {\n  storeName = $('Guardar store base en BD').first().json.store_name;\n  prev = $('¿Existe store base?').first();\n} catch(e) {\n  prev = $('¿Existe store base?').first();\n  storeName = prev.json.base_store_name;\n}\n\nreturn [{\n  json: {\n    filename: prev.json.filename,\n    descripcion: prev.json.descripcion,\n    mimetype: prev.json.mimetype,\n    store_name: storeName\n  },\n  binary: prev.binary\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
